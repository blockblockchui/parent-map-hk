# Event Image Sync - 環境變數配置
# 將此文件複製為 .env 並填入實際值

# Google Sheets API
GOOGLE_SHEETS_ID=1xUL8jiJckSTe3ScThsh-USNWb2DqpGnkroGdarafJgk

# Supabase 配置
# 注意：上傳文件到 Storage 需要使用 SERVICE_ROLE_KEY，而不是 ANON_KEY
# 在 Supabase Dashboard → Project Settings → API 中獲取 service_role key
NEXT_PUBLIC_SUPABASE_URL=https://krlqzkxqlxoetxxjqamh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase Storage Bucket 名稱
SUPABASE_BUCKET=event-images

# 可選：本地圖片暫存目錄
LOCAL_DOWNLOAD_DIR=temp_event_images
